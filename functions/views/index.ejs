<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EJS</title>
</head>
<body>
 
   <!-- Mostrando o nome do objeto passado -->
   <h1> Alunos </h1>

   <ul>
        <% dados.forEach(function(alunos) {%>
            <li><%= alunos.nome %> - Idade: <%= alunos.mae %></li>
        <% });%> 
    </ul>
     
   <h1>Olá, <%= dados.nome %>!</h1>
   <h1>Olá, <%= dados.mae %>!</h1>
    
</body>
</html>